<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" packages="org.apache.jmeter.reporters,org.apache.jmeter.gui">
  <!-- 
    JMeter Log4j2 Configuration
    Fixes: "WARN StatusConsoleListener The use of package scanning to locate plugins is deprecated"
    
    This configuration explicitly declares all required plugins instead of using package scanning.
  -->
  
  <Appenders>
    <!-- Console appender for container logs -->
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} %-5level %c{1.} - %msg%n"/>
    </Console>
    
    <!-- File appender for JMeter log -->
    <File name="JMeterLog" fileName="/tmp/jmeter.log" append="false">
      <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5p %c{1}:%L - %m%n"/>
    </File>
  </Appenders>
  
  <Loggers>
    <!-- JMeter core loggers -->
    <Logger name="org.apache.jmeter" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="JMeterLog"/>
    </Logger>
    
    <Logger name="org.apache.jorphan" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="JMeterLog"/>
    </Logger>
    
    <!-- Reduce noise from HTTP client -->
    <Logger name="org.apache.http" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="JMeterLog"/>
    </Logger>
    
    <!-- Reduce noise from BeanShell -->
    <Logger name="bsh" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="JMeterLog"/>
    </Logger>
    
    <!-- Root logger -->
    <Root level="INFO">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="JMeterLog"/>
    </Root>
  </Loggers>
</Configuration>