{
  "testSuite": [
    {
      "testId": "api-load-test",
      "testScript": "tests/api-load.jmx",
      "numOfContainers": 3,
      "threads": 100,
      "duration": "15m",
      "dataFiles": [
        "data/users.csv",
        "data/products.csv"
      ],
      "execute": true,
      "jvmArgs": "-Xms512m -Xmx2g",
      "jmeterProperties": {
        "hostname": "api.example.com",
        "protocol": "https",
        "rampup": "60"
      }
    },
    {
      "testId": "stress-test",
      "testScript": "tests/stress.jmx",
      "numOfContainers": 5,
      "threads": 200,
      "duration": "30m",
      "execute": true,
      "jvmArgs": "-Xms1g -Xmx3g"
    },
    {
      "testId": "spike-test",
      "testScript": "tests/spike.jmx",
      "numOfContainers": 2,
      "threads": 500,
      "duration": "5m",
      "execute": false
    }
  ]
}