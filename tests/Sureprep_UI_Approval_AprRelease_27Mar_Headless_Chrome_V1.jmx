import org.openqa.selenium.support.ui.WebDriverWait; 
import java.time.Duration; 
import org.openqa.selenium.chrome.ChromeOptions;
import org.openqa.selenium.JavascriptExecutor;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.chrome.ChromeDriver;
import org.apache.commons.io.FileUtils;
import java.io.File;
import java.io.IOException;
import org.openqa.selenium.OutputType;
import org.openqa.selenium.TakesScreenshot;

def takeScreenshot(WebDriver driver, String screenshotName) {
    try {
        if (driver == null) {
            throw new IllegalStateException(&quot;WebDriver is not initialized.&quot;)
        }

        String samplerName = SampleResult.getSampleLabel();
        File screenshot = ((TakesScreenshot) driver).getScreenshotAs(OutputType.FILE)
        String filename = &quot;${jmeterDir}/&quot; + samplerName + &quot;_error_&quot; + System.currentTimeMillis() + screenshotName + &quot;.png&quot;
        FileUtils.copyFile(screenshot, new File(filename))
        println(&quot;Screenshot captured: &quot; + filename)
    } catch (Exception e) {
        println(&quot;Failed to capture screenshot: &quot; + e.message)
    }
}

def getProgressWidth(WebElement amp) {
    try {
        String style = amp.getAttribute(&quot;style&quot;)
        if (style == null || style.trim().isEmpty()) {
            return &quot;&quot;
        }

        def matcher = (style =~ /width\s*:\s*([0-9]+%)/)
        if (matcher.find()) {
            return matcher.group(1).trim()
        }
        return &quot;&quot;
    } catch (Exception e) {
        return &quot;&quot;
    }
}

WebDriver driver=vars.getObject(&apos;mydriver&apos;);
driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));
WebDriverWait wait =new WebDriverWait(driver,Duration.ofSeconds(120));

// click on Adjustment Type dropdown
driver.findElement(By.xpath(&quot;//*[@id=&apos;picklistSelectMaterialDesign&apos;]&quot;)).click();

// wait until dropdown option is clickable
wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;/html/body/div[2]/md-select-menu/md-content/md-option[2]/div[1]&quot;))); 
driver.findElement(By.xpath(&quot;/html/body/div[2]/md-select-menu/md-content/md-option[2]/div[1]&quot;)).click();

wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;/html/body/span/div[3]/div[6]/div/div/div/cart-grid/div[2]/div[1]/div/div[1]/div[2]/div[2]/div/div[1]/div/div/div[5]/div/dynamic-field/div/div/md-input-container/input&quot;))); 
Thread.sleep(5000);

driver.findElement(By.xpath(&quot;/html/body/span/div[3]/div[6]/div/div/div/cart-grid/div[2]/div[1]/div/div[1]/div[2]/div[2]/div/div[1]/div/div/div[5]/div/dynamic-field/div/div/md-input-container/input&quot;)).sendKeys(&quot;21&quot;);

long startTime = System.currentTimeMillis();

try {
    // click Save &amp; Return to Cart
    driver.findElement(By.xpath(&quot;/html/body/span/div[3]/div[2]/div/div/div[2]/div/display-actions/div/button[4]&quot;)).click();

    By progressBarBy = By.xpath(&quot;//*[@id=&apos;progress-bar&apos;]/div/div&quot;);
    By addMoreProductsBy = By.xpath(&quot;//*[@buttonid=&apos;id_task_left_addmoreproducts&apos;]&quot;);

    WebElement amp = wait.until(ExpectedConditions.presenceOfElementLocated(progressBarBy));
    String w = getProgressWidth(amp);

    log.info(&quot;Just after click Save &amp; Return to Cart : &quot; + amp.getAttribute(&apos;style&apos;));
    log.info(&quot;Initial progress width: &quot; + w);

    int retry = 0;
    int maxRetry = 180;   // max 60 seconds
    boolean completed = false;

    while (retry &lt; maxRetry) {
        try {
            amp = driver.findElement(progressBarBy);   // re-locate each time
            w = getProgressWidth(amp);

            log.info(&quot;Retry &quot; + retry + &quot; - progress width: &quot; + w);

            // Break condition 1: progress reached 100%
            if (&quot;100%&quot;.equals(w)) {
                completed = true;
                log.info(&quot;Break: progress reached 100%&quot;);
                break;
            }

            // Break condition 2: next button is already ready
            if (driver.findElements(addMoreProductsBy).size() &gt; 0 &amp;&amp;
                driver.findElement(addMoreProductsBy).isDisplayed()) {
                completed = true;
                log.info(&quot;Break: Add More Products button is visible&quot;);
                break;
            }

        } catch (Exception ex) {
            log.info(&quot;Retry &quot; + retry + &quot; error: &quot; + ex.getMessage());
        }

        Thread.sleep(1000);
        retry++;
    }

    if (!completed) {
        throw new RuntimeException(&quot;Timed out after &quot; + maxRetry + &quot; seconds waiting for Save &amp; Return to Cart to complete. Last progress: &quot; + w);
    }

    log.info(&quot;After loop final style : &quot; + amp.getAttribute(&apos;style&apos;));

    // final wait
    wait.until(ExpectedConditions.elementToBeClickable(addMoreProductsBy));

} catch (Exception e) {
    System.out.println(e);
    SampleResult.sampleEnd();
    SampleResult.setSuccessful(false);
    SampleResult.setResponseMessage(e.getMessage());
    takeScreenshot(driver, &quot;2&quot;);
    return;
}

long endTime = System.currentTimeMillis();

SampleResult.setStartTime(startTime)
SampleResult.setEndTime(endTime)</stringProp>
