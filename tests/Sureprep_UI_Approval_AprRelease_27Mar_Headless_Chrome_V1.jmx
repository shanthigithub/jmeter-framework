WebDriver driver=vars.getObject(&apos;mydriver&apos;);
driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));
driver.manage().window().setSize(new org.openqa.selenium.Dimension(1920, 1080))
WebDriverWait wait =new WebDriverWait(driver,Duration.ofSeconds(120));

long startTime = System.currentTimeMillis();

try {

//driver.findElement(By.xpath(&quot;//*[contains(text(),&apos;Products&apos;)]/parent::span/parent::a&quot;)).click();
By products = By.xpath(&quot;//*[contains(text(),&apos;Products&apos;)]/parent::span/parent::a&quot;);
WebElement productLink = wait.until(ExpectedConditions.visibilityOfElementLocated(products));


((JavascriptExecutor) driver).executeScript(
    &quot;arguments[0].scrollIntoView({block:&apos;center&apos;, inline:&apos;nearest&apos;});&quot;,
    productLink
);

wait.until(ExpectedConditions.elementToBeClickable(productLink)).click();
//wait until choose price book button is visible
wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//a[@title=&apos;Choose Price Book&apos;]&quot;)));
	 
}

 catch (Exception e) {
 	  System.out.println(e);
	   SampleResult.sampleEnd();
        SampleResult.setSuccessful(false);
        SampleResult.setResponseMessage(e.getMessage());

        takeScreenshot(driver, &quot;2&quot;);
        return;
 }

 long endTime = System.currentTimeMillis();


SampleResult.setStartTime(startTime)
SampleResult.setEndTime(endTime)
 

