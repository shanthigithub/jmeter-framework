WebElement productName = driver.findElement(By.xpath(&quot;/html/body/span/div[3]/div[6]/div/div/div[2]/div/div[2]/div[2]/div[&quot; + i + &quot;]/ul/li/catalog-product/div/div[1]/div/h3/a&quot;));

	if(!element.isSelected() and count &lt; 21) {		
		int elementPosition = checkbox.getLocation().getY();
   		String js = String.format(&quot;window.scroll(0, %s)&quot;, elementPosition-237);
   	//	log.info(&quot;displayed : &quot; + elementPosition);
   		((JavascriptExecutor)driver).executeScript(js);
   		if(subscriptionFee.getText() == &apos;Subscription Fee&apos;)
   		{
   		log.info(&quot;productName : &quot; + productName.getText());
		checkbox.click();
		count++
   		}
		} 	
}

