WebDriver driver=vars.getObject(&apos;mydriver&apos;);
driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));
WebDriverWait wait =new WebDriverWait(driver,Duration.ofSeconds(120));
long startTime ;//initialisation var
 
try {
	
 
 	String parent = driver.getWindowHandle();

 //click on Approve/Reject button
	 driver.findElement(By.xpath(&quot;//button[contains(text(), &apos;Approve / Reject&apos;)]&quot;)).click();
	 Thread.sleep(10000);

	Set&lt;String&gt;s=driver.getWindowHandles();
	// Now iterate using Iterator
Iterator&lt;String&gt; I1= s.iterator();
	    
      while(I1.hasNext())
	{

		String child_window=I1.next();


		if(!parent.equals(child_window))
		{
		driver.switchTo().window(child_window);
		System.out.println(&quot;Printing child window title&quot;);
		System.out.println(driver.switchTo().window(child_window).getTitle());
		
		driver.close();
		}

	}

	Thread.sleep(5000);

//wait until the new account popup windows cancel button is visble
//	   wait.until(ExpectedConditions.elementToBeClickable(By.id(&quot;username&quot;))); 
// switch back to the original window
	   driver.switchTo().window(parent); 

	   
	 wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;//button[contains(text(), &apos;Approve / Reject&apos;)]&quot;))); 	
	 Thread.sleep(5000);

	   startTime = System.currentTimeMillis();


Boolean isPresent = driver.findElements(By.xpath(&quot;//*[@title=&apos;accessibility title&apos;]&quot;)).size() &gt; 0


if(!isPresent){

