def takeScreenshot(WebDriver driver, String screenshotName) {
    try {
        if (driver == null) {
            throw new IllegalStateException(&quot;WebDriver is not initialized.&quot;)
        }

        String debugDir = &quot;C:/JMeter/WebDriverDebug&quot;
        new File(debugDir).mkdirs()

        String samplerName = SampleResult.getSampleLabel()
        File screenshot = ((TakesScreenshot) driver).getScreenshotAs(OutputType.FILE)
        String filename = debugDir + &quot;/&quot; + samplerName + &quot;_error_&quot; + System.currentTimeMillis() + &quot;_&quot; + screenshotName + &quot;.png&quot;
        FileUtils.copyFile(screenshot, new File(filename))
        println(&quot;Screenshot captured: &quot; + filename)
    } catch (Exception e) {
        println(&quot;Failed to capture screenshot: &quot; + e.message)
    }
}

WebDriver driver = vars.getObject(&apos;mydriver&apos;)
driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10))
driver.manage().window().setSize(new Dimension(1920, 1080))

WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(180))

int count = 0

try {
    for (int i = 1; i &lt; 21; i++) {

        List&lt;WebElement&gt; elements = driver.findElements(By.xpath(&quot;(//*[@class=&apos;main-block__listings&apos;])[&quot; + i + &quot;]&quot;))
        List&lt;WebElement&gt; checkboxes = driver.findElements(By.xpath(&quot;(//span[contains(@class,&apos;listing-check&apos;) and contains(@class,&apos;checkbox-override&apos;)])[&quot; + i + &quot;]&quot;))
        List&lt;WebElement&gt; subscriptionFees = driver.findElements(By.xpath(&quot;/html/body/span[1]/div[3]/div[6]/div/div/div[2]/div/div[2]/div[2]/div[&quot; + i + &quot;]/ul/li/catalog-product/div/div[2]/div[1]/div/span[1]/span&quot;))
        List&lt;WebElement&gt; productNames = driver.findElements(By.xpath(&quot;/html/body/span/div[3]/div[6]/div/div/div[2]/div/div[2]/div[2]/div[&quot; + i + &quot;]/ul/li/catalog-product/div/div[1]/div/h3/a&quot;))

        if (elements.size() == 0 || checkboxes.size() == 0 || subscriptionFees.size() == 0 || productNames.size() == 0) {
            log.info(&quot;Skipping row &quot; + i + &quot; because one or more elements are missing&quot;)
            continue
        }

        WebElement element = elements.get(0)
        WebElement checkbox = checkboxes.get(0)
        WebElement subscriptionFee = subscriptionFees.get(0)
        WebElement productName = productNames.get(0)

        if (count &lt; 21) {
            ((JavascriptExecutor) driver).executeScript(
                &quot;arguments[0].scrollIntoView({block:&apos;center&apos;, inline:&apos;nearest&apos;});&quot;,
                checkbox
            )
            Thread.sleep(500)

            if (subscriptionFee.getText().trim().equalsIgnoreCase(&quot;Subscription Fee&quot;)) {
                log.info(&quot;productName : &quot; + productName.getText())

                try {
                    checkbox.click()
                } catch (Exception ex) {
                    ((JavascriptExecutor) driver).executeScript(&quot;arguments[0].click();&quot;, checkbox)
                }

                count++
                Thread.sleep(700)
            }
        }
    }

    By gtpBy = By.xpath(&quot;//*[@class=&apos;ands-btn ands-secondary GoToPricing active-true md-button&apos;]&quot;)
    WebElement gtp = driver.findElement(gtpBy)

    log.info(&quot;Before Add To Cart : &quot; + gtp.getAttribute(&quot;disabled&quot;))

    Thread.sleep(5000)

    long startTime = System.currentTimeMillis()

    try {
        WebElement addToCart = driver.findElement(By.xpath(&quot;//*[@class=&apos;ands-btn ands-primary cartTheme md-button md-ink-ripple&apos;]&quot;))
        ((JavascriptExecutor) driver).executeScript(&quot;arguments[0].scrollIntoView({block:&apos;center&apos;});&quot;, addToCart)
      //  Thread.sleep(500)

        try {
            addToCart.click()
        } catch (Exception ex) {
            ((JavascriptExecutor) driver).executeScript(&quot;arguments[0].click();&quot;, addToCart)
        }

        int retry = 0
        int maxRetry = 40

        while (retry &lt; maxRetry) {
            try {
                gtp = driver.findElement(gtpBy)
                String disabledValue = gtp.getAttribute(&quot;disabled&quot;)
                log.info(&quot;GoToPricing disabled value: &quot; + disabledValue)

                if (disabledValue != null) {
                    break
                }
            } catch (Exception ex) {
                log.info(&quot;Error checking GoToPricing state: &quot; + ex.getMessage())
            }

            Thread.sleep(1000)
            retry++
        }

        if (retry == maxRetry) {
            throw new RuntimeException(&quot;Timed out waiting for GoToPricing button to become disabled&quot;)
        }

        log.info(&quot;After Add To Cart : &quot; + gtp.getAttribute(&quot;disabled&quot;))

        wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;//*[@buttonid=&apos;id_task_left_gotopricing&apos;]&quot;)))

    } catch (Exception e) {
        System.out.println(e)
        SampleResult.sampleEnd()
        SampleResult.setSuccessful(false)
        SampleResult.setResponseMessage(e.getMessage())
        takeScreenshot(driver, &quot;2&quot;)
        throw e
    }

    long endTime = System.currentTimeMillis()

    SampleResult.setStartTime(startTime)
    SampleResult.setEndTime(endTime)
    SampleResult.setSuccessful(true)
    SampleResult.setResponseCode(&quot;200&quot;)
    SampleResult.setResponseMessage(&quot;Success&quot;)

} catch (Exception e) {
    log.error(&quot;Script failed: &quot; + e.getMessage(), e)
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode(&quot;500&quot;)
    SampleResult.setResponseMessage(e.getMessage())
    takeScreenshot(driver, &quot;main_failure&quot;)
    throw e
