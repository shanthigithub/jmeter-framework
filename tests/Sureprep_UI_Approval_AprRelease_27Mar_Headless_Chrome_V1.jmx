          <stringProp name="script">import org.openqa.selenium.By
import org.openqa.selenium.WebDriver
import org.openqa.selenium.WebElement
import org.openqa.selenium.support.ui.WebDriverWait
import java.time.Duration
import org.openqa.selenium.JavascriptExecutor
import org.openqa.selenium.support.ui.ExpectedConditions
import org.apache.commons.io.FileUtils
import java.io.File
import org.openqa.selenium.OutputType
import org.openqa.selenium.TakesScreenshot

def takeScreenshot(WebDriver driver, String screenshotName) {
    try {
        if (driver == null) {
            throw new IllegalStateException(&quot;WebDriver is not initialized.&quot;)
        }

        String samplerName = SampleResult.getSampleLabel()
        File screenshot = ((TakesScreenshot) driver).getScreenshotAs(OutputType.FILE)
        String filename = &quot;${jmeterDir}/&quot; + samplerName + &quot;_error_&quot; + System.currentTimeMillis() + &quot;_&quot; + screenshotName + &quot;.png&quot;
        FileUtils.copyFile(screenshot, new File(filename))
        println(&quot;Screenshot captured: &quot; + filename)
    } catch (Exception e) {
        println(&quot;Failed to capture screenshot: &quot; + e.message)
    }
}

def getProgressWidth(WebElement amp) {
    try {
        String style = amp.getAttribute(&quot;style&quot;)
        if (style == null || style.trim().isEmpty()) {
            return &quot;&quot;
        }

        def matcher = (style =~ /width\s*:\s*([0-9]+%)/)
        if (matcher.find()) {
            return matcher.group(1).trim()
        }
        return &quot;&quot;
    } catch (Exception e) {
        return &quot;&quot;
    }
}

WebDriver driver = vars.getObject(&apos;mydriver&apos;)
driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(20))
WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(180))

long startTime = System.currentTimeMillis()

try {
    By goToPricingBy = By.xpath(&quot;//button[contains(@class,&apos;ands-btn&apos;) and contains(@class,&apos;GoToPricing&apos;)]&quot;)
    By progressBarBy = By.xpath(&quot;//*[@id=&apos;progress-bar&apos;]/div/div&quot;)
    By addMoreProductsBy = By.xpath(&quot;//*[@buttonid=&apos;id_task_left_addmoreproducts&apos;]&quot;)

    WebElement ele00a = wait.until(ExpectedConditions.elementToBeClickable(goToPricingBy))
    ((JavascriptExecutor)driver).executeScript(&quot;arguments[0].click();&quot;, ele00a)

    WebElement amp = wait.until(ExpectedConditions.presenceOfElementLocated(progressBarBy))

    String w = getProgressWidth(amp)
    log.info(&quot;Initial progress width: &quot; + w)

    int maxWaitSeconds = 180
    int elapsed = 0
    boolean completed = false

    while (elapsed &lt; maxWaitSeconds) {
        amp = driver.findElement(progressBarBy)   // re-locate element each time
        w = getProgressWidth(amp)

        log.info(&quot;Progress width at &quot; + elapsed + &quot; sec: &quot; + w)

        if (&quot;100%&quot;.equals(w)) {
            completed = true
            log.info(&quot;Progress reached 100%&quot;)
            break
        }

        Thread.sleep(1000)
        elapsed++
    }

    if (!completed) {
        throw new RuntimeException(&quot;Timeout: progress bar did not reach 100% within &quot; + maxWaitSeconds + &quot; seconds. Last value: &quot; + w)
    }

    wait.until(ExpectedConditions.elementToBeClickable(addMoreProductsBy))

    SampleResult.setSuccessful(true)
    SampleResult.setResponseCode(&quot;200&quot;)
    SampleResult.setResponseMessage(&quot;Success&quot;)

} catch (Exception e) {
    System.out.println(e)
    SampleResult.sampleEnd()
    SampleResult.setSuccessful(false)
    SampleResult.setResponseMessage(e.getMessage())
    takeScreenshot(driver, &quot;2&quot;)
    return
}

long endTime = System.currentTimeMillis()

SampleResult.setStartTime(startTime)
SampleResult.setEndTime(endTime)</stringProp>
