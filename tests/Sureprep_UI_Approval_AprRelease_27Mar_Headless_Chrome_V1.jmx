        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Step_002_Enterprise_Login_2" enabled="true">
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.openqa.selenium.By; 
import org.openqa.selenium.WebDriver; 
import org.openqa.selenium.firefox.FirefoxOptions;
import org.openqa.selenium.firefox.FirefoxDriver;
import org.openqa.selenium.edge.EdgeOptions;
import org.openqa.selenium.edge.EdgeDriver;
import org.openqa.selenium.WebElement; 
import org.openqa.selenium.support.ui.Select; 
import org.openqa.selenium.support.ui.WebDriverWait; 
import java.time.Duration; 
import org.openqa.selenium.chrome.ChromeOptions;
import org.openqa.selenium.JavascriptExecutor;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.chrome.ChromeDriver;
import org.apache.commons.io.FileUtils;
import java.io.File;
import java.io.IOException;
import org.openqa.selenium.OutputType;
import org.openqa.selenium.TakesScreenshot;
import org.openqa.selenium.Keys;
import java.awt.AWTException;
import java.awt.Robot;
import java.awt.event.KeyEvent;
import org.openqa.selenium.interactions.Actions;

WebDriver driver;
    
String browser=&quot;${browserName}&quot;;
if(browser.toLowerCase().equalsIgnoreCase(&quot;firefox&quot;)){
    System.setProperty(&quot;webdriver.gecko.driver&quot;, &quot;${geckoDriver}&quot;);
    String firefoxBinaryPath = &quot;${firefoxPath}&quot;;
    FirefoxOptions options = new FirefoxOptions();
    options.setBinary(firefoxBinaryPath);
    if( &quot;${headless}&quot; == &quot;true&quot; ) {
        options.addArguments(&quot;--headless&quot;);
    }
    options.addArguments(&quot;window-size=1920,1080&quot;);
 //   options.addArguments(&quot;start-maximized&quot;); // open Browser in maximized mode    
    driver = new FirefoxDriver(options);
}

if(browser.toLowerCase().equalsIgnoreCase(&quot;chrome&quot;)){
    System.setProperty(&quot;webdriver.chrome.driver&quot;, &quot;${chromeDriver}&quot;);
    String chromeBinaryPath = &quot;${chromePath}&quot;;
    ChromeOptions options = new ChromeOptions();
    options.setBinary(chromeBinaryPath);
    if( &quot;${headless}&quot; == &quot;true&quot; ) {
        options.addArguments(&quot;--headless&quot;);
    }
  //  options.addArguments(&quot;--headless=new&quot;);
    options.addArguments(&quot;--window-size=1920,1080&quot;);
    options.addArguments(&quot;--start-maximized&quot;); // open Browser in maximized mode
    options.addArguments(&quot;--disable-infobars&quot;); // disabling infobars
    options.addArguments(&quot;--disable-extensions&quot;); // disabling extensions
    options.addArguments(&quot;--disable-dev-shm-usage&quot;); // overcome limited resource problems
    options.addArguments(&quot;--no-sandbox&quot;); // Bypass OS security model
    // Set Chrome options to disable notifications   
    options.addArguments(&quot;--disable-notifications&quot;);
    // Enable software rendering for screenshots in Xvfb/containerized environments
    options.addArguments(&quot;--use-gl=swiftshader&quot;);
    options.addArguments(&quot;--enable-logging&quot;);
    options.addArguments(&quot;--force-device-scale-factor=1&quot;);
 
    driver = new ChromeDriver(options);
}

if(browser.toLowerCase().equalsIgnoreCase(&quot;edge&quot;)){
    System.setProperty(&quot;webdriver.edge.driver&quot;, &quot;${edgeDriverPath}&quot;);
    String edgeBinaryPath = &quot;${edgePath}&quot;;
    EdgeOptions options = new EdgeOptions();
    options.setBinary(edgeBinaryPath);
    options.addArguments(&quot;--headless=new&quot;);
    options.addArguments(&quot;--window-size=1920,1080&quot;);
    options.addArguments(&quot;--start-maximized&quot;); // open Browser in maximized mode
    options.addArguments(&quot;--disable-infobars&quot;); // disabling infobars
    options.addArguments(&quot;--disable-extensions&quot;); // disabling extensions
    options.addArguments(&quot;--disable-dev-shm-usage&quot;); // overcome limited resource problems
    options.addArguments(&quot;--no-sandbox&quot;); // Bypass OS security model
    // Enable software rendering for screenshots in Xvfb/containerized environments
    options.addArguments(&quot;--use-gl=swiftshader&quot;);
    options.addArguments(&quot;--enable-logging&quot;);
    options.addArguments(&quot;--force-device-scale-factor=1&quot;);
    driver = new EdgeDriver(options);
}

def takeScreenshot(WebDriver driver, String screenshotName) {
    try {
        if (driver == null) {
            throw new IllegalStateException(&quot;WebDriver is not initialized.&quot;)
        }

        // Get the current sampler name
        String samplerName = SampleResult.getSampleLabel();
        File screenshot = ((TakesScreenshot) driver).getScreenshotAs(OutputType.FILE)
        String filename = &quot;${jmeterDir}/&quot; + samplerName + &quot;_error_&quot; + System.currentTimeMillis() + screenshotName + &quot;.png&quot;
        FileUtils.copyFile(screenshot, new File(filename))
        println(&quot;Screenshot captured: &quot; + filename)
    } catch (Exception e) {
        println(&quot;Failed to capture screenshot: &quot; + e.message)
    }
}

driver.manage().window().maximize();
driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));
WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(240)); 

vars.putObject(&apos;mydriver&apos;, driver);

long startTime = System.currentTimeMillis();

try { 
	
    System.out.println(&quot;Open the website&quot;, );
    driver.get(&quot;https://thomsonreutersglis2e--uat.sandbox.my.salesforce.com/secur/frontdoor.jsp?sid=${access_token}&quot;);
    
// wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//*[@id=&apos;Login&apos;]&quot;)));
	var iframe =driver.findElement(By.xpath(&quot;(//*[@title=&apos;dashboard&apos;])&quot;));
driver.switchTo().frame(iframe);
wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//*[contains(@class,&apos;widget-container&apos;)][1]&quot;)));

// use this //*[contains(@class,&apos;widget-container&apos;)]
	//   wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;(//*[@class=&apos;ps-container&apos;])[1]&quot;)));

	   
	
//System.out.println(&quot;Iframe exit&quot;)
driver.switchTo().defaultContent();
		
} catch (Exception e) {
    System.out.println(e);
    SampleResult.sampleEnd();
    SampleResult.setSuccessful(false);
    SampleResult.setResponseMessage(e.getMessage());
    String samplerName = SampleResult.getSampleLabel();
    takeScreenshot(driver, &quot;1&quot;);
    return;
}

long endTime = System.currentTimeMillis();

SampleResult.setStartTime(startTime);




 </stringProp>
