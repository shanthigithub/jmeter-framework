            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">import java.security.KeyFactory  

import java.security.Signature  

import java.security.spec.PKCS8EncodedKeySpec  

import java.util.Base64

// ============================================================  

// Configuration  

// ============================================================  

def CONSUMER_KEY = vars.get(&quot;CONSUMER_KEY&quot;)  

def USERNAME = vars.get(&quot;USERNAME&quot;)  

def LOGIN_URL = vars.get(&quot;LOGIN_URL&quot;)  

def PRIVATE_KEY = vars.get(&quot;PRIVATE_KEY&quot;)

// ============================================================  

// JWT Header &amp; Payload (compact JSON - no extra spaces)  

// ============================================================  

def header = &apos;{&quot;alg&quot;:&quot;RS256&quot;,&quot;typ&quot;:&quot;JWT&quot;}&apos;

def now = (long)(System.currentTimeMillis() / 1000)  

def exp = now + (3 * 60)

def payload = &apos;{&quot;iss&quot;:&quot;&apos; + CONSUMER_KEY + &apos;&quot;,&quot;sub&quot;:&quot;&apos; + USERNAME + &apos;&quot;,&quot;aud&quot;:&quot;&apos; + LOGIN_URL + &apos;&quot;,&quot;iat&quot;:&apos; + now + &apos;,&quot;exp&quot;:&apos; + exp + &apos;}&apos;

// ============================================================  

// Base64 URL Encode (NO PADDING, URL-SAFE)  

// ============================================================  

def base64UrlEncode(byte[] data) {  

    return Base64.getUrlEncoder().withoutPadding().encodeToString(data)  

}

def encodedHeader = base64UrlEncode(header.getBytes(&quot;UTF-8&quot;))  

def encodedPayload = base64UrlEncode(payload.getBytes(&quot;UTF-8&quot;))  

def signatureInput = encodedHeader + &quot;.&quot; + encodedPayload

// ============================================================  

// Clean and Parse Private Key  

// ============================================================  

def cleanKey = PRIVATE_KEY  

    .replace(&quot;-----BEGIN PRIVATE KEY-----&quot;, &quot;&quot;)  

    .replace(&quot;-----END PRIVATE KEY-----&quot;, &quot;&quot;)  

    .replace(&quot;-----BEGIN RSA PRIVATE KEY-----&quot;, &quot;&quot;)  

    .replace(&quot;-----END RSA PRIVATE KEY-----&quot;, &quot;&quot;)  

    .replace(&quot;\\n&quot;, &quot;&quot;)      // Remove literal \n  

    .replace(&quot;\n&quot;, &quot;&quot;)       // Remove actual newlines  

    .replace(&quot;\r&quot;, &quot;&quot;)       // Remove carriage returns  

    .replace(&quot; &quot;, &quot;&quot;)        // Remove spaces  

    .trim()

log.info(&quot;Clean key length: &quot; + cleanKey.length())

def keyBytes = Base64.getDecoder().decode(cleanKey)  

def keySpec = new PKCS8EncodedKeySpec(keyBytes)  

def keyFactory = KeyFactory.getInstance(&quot;RSA&quot;)  

def privateKey = keyFactory.generatePrivate(keySpec)

// ============================================================  

// Sign  

// ============================================================  

def signature = Signature.getInstance(&quot;SHA256withRSA&quot;)  

signature.initSign(privateKey)  

signature.update(signatureInput.getBytes(&quot;UTF-8&quot;))  

def signedBytes = signature.sign()

// IMPORTANT: Use URL-safe Base64 encoding for signature  

def encodedSignature = base64UrlEncode(signedBytes)

// ============================================================  

// Final JWT - Remove any whitespace  

// ============================================================  

def jwtAssertion = (signatureInput + &quot;.&quot; + encodedSignature).trim()

// Verify no invalid characters  

if (jwtAssertion.contains(&quot;+&quot;) || jwtAssertion.contains(&quot;/&quot;) || jwtAssertion.contains(&quot;=&quot;)) {  

    log.error(&quot;JWT contains invalid characters!&quot;)  

}

log.info(&quot;JWT Generated: &quot; + jwtAssertion.substring(0, 50) + &quot;...&quot;)  

vars.put(&quot;jwt_assertion&quot;, jwtAssertion)  
 </stringProp>
