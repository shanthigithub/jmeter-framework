{
  "jobDefinitionName": "jmeter-batch-job",
  "type": "container",
  "platformCapabilities": ["FARGATE"],
  "containerProperties": {
    "image": "623035187488.dkr.ecr.us-east-1.amazonaws.com/jmeter-batch:latest",
    "jobRoleArn": "arn:aws:iam::623035187488:role/JMeterBatchStack-BatchJobRole37A83758-OXGKIYYitZKc",
    "executionRoleArn": "arn:aws:iam::623035187488:role/JMeterBatchStack-BatchExecutionRole3527F47B-glO14NezV13B",
    "resourceRequirements": [
      {"type": "VCPU", "value": "0.5"},
      {"type": "MEMORY", "value": "2048"}
    ],
    "networkConfiguration": {
      "assignPublicIp": "ENABLED"
    },
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/aws/batch/jmeter",
        "awslogs-region": "us-east-1",
        "awslogs-stream-prefix": "jmeter"
      }
    },
    "environment": [
      {"name": "CONFIG_BUCKET", "value": "jmeter-batch-config"},
      {"name": "RESULTS_BUCKET", "value": "jmeter-batch-results"},
      {"name": "AWS_REGION", "value": "us-east-1"}
    ],
    "command": ["echo", "JMeter container - command will be set by Lambda"]
  },
  "retryStrategy": {
    "attempts": 1
  },
  "timeout": {
    "attemptDurationSeconds": 7200
  }
}