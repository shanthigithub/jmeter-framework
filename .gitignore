# JMeter Test Files (stored in S3, not GitHub)
# Ignore entire tests directory - test files should be uploaded to S3, not committed to GitHub
tests/
data/*.csv
data/*.txt

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# AWS CDK
iac/cdk.out/
iac/node_modules/
iac/.cdk.staging/

# Temporary files
*.log
*.tmp
*.bak

# AWS credentials (never commit)
.aws/
credentials
*.pem
*.key

# Build artifacts
dist/
build/
*.pyc
__pycache__/

# Local test results
results/
*.jtl
# Ignore JMeter result XML files, but keep configuration files
*.jmx.xml
results*.xml
summary*.xml
# Allow Log4j2 config
!docker/log4j2.xml

# Git ignore for uploaded files
github-actions-trust-policy.json
github-actions-permissions.json

# Prevent markdown documentation files
*.md
*.MD
README*
CHANGELOG*

# Exclude copied review directories
cp_jmeter-dev/
k6-framework-personal/
